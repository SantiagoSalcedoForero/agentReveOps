# Meta WhatsApp
WHATSAPP_VERIFY_TOKEN=verifty-bot-verify-2026
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v18.0

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Supabase (service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CRM
CRM_URL=https://crm.verifty.com

# Google OAuth (para refresh de access_tokens del CRM cuando expiren)
# Estos son los MISMOS client_id/secret que Verifty usó en Supabase Auth → Google Provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# (opcional, legacy) Google service account JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# Bot config
QUALIFIED_SCORE_THRESHOLD=10
MAX_BOT_RETRIES=2
BOT_TIMEZONE=America/Bogota

# Logging
LOG_LEVEL=INFO

# Admin API (protege /admin/stats/*). Genera uno con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=
